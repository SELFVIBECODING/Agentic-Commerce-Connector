# =============================================================================
# Agentic Commerce Connector — composed environment template
# =============================================================================
# For readability, the full set of env vars is split by concern into
# `env-examples/`. This file is the concatenated view. Either:
#
#   A) Edit this file directly and save as `.env`
#   B) Compose from `env-examples/`:
#        cat env-examples/base.env \
#            env-examples/shopify.env \
#            env-examples/nexus.env > .env
#      (swap `shopify.env` for `woocommerce.env` as needed)
#
# See `env-examples/README.md` for what belongs in each section
# and where to obtain every value.
# =============================================================================


# ============================================================================
# BASE (always required)
# ============================================================================
PLATFORM=shopify                 # shopify | woocommerce
PAYMENT_PROVIDER=nexus           # nexus

MERCHANT_DID=did:example:my-store
TRANSPORT=http
PORTAL_PORT=10000
SELF_URL=http://commerce-agent:10000
DATABASE_URL=postgresql://user:password@localhost:5432/commerce_agent

# UCP HMAC cart-token secret — generate with: openssl rand -hex 32
UCP_CART_TOKEN_SECRET=
UCP_TOKEN_TTL_SECONDS=900

PAYMENT_CURRENCY=XSGD
CHECKOUT_FIXED_RATE=1.00
CHECKOUT_RATE_LOCK_MINUTES=5


# ============================================================================
# SHOPIFY (required when PLATFORM=shopify)
# ============================================================================
# Create a Custom App in Shopify admin → Settings → Apps → Develop apps.
# Enable Storefront API (read_products, read_inventory) + Admin API
# (read_orders, write_orders). Copy tokens from API credentials.
SHOPIFY_STORE_URL=https://my-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=
SHOPIFY_ADMIN_TOKEN=shpat_
SHOPIFY_API_VERSION=2025-07


# ============================================================================
# WOOCOMMERCE (required when PLATFORM=woocommerce)
# ============================================================================
# Generate an API key in WooCommerce admin → Settings → Advanced → REST API
# (Read/Write). The secret is shown once — copy it immediately.
# HTTPS mandatory.
WOO_BASE_URL=https://my-store.example.com
WOO_CONSUMER_KEY=ck_
WOO_CONSUMER_SECRET=cs_
WOO_API_VERSION=wc/v3
WOO_REQUEST_TIMEOUT_MS=15000
WOO_MAX_RETRIES=3


# ============================================================================
# NEXUS PAYMENT (required when PAYMENT_PROVIDER=nexus)
# ============================================================================
# MERCHANT_SIGNER_PRIVATE_KEY signs NUPS quotes. Generate a dedicated key
# (do NOT reuse the payout wallet key). MERCHANT_PAYMENT_ADDRESS is the
# on-chain recipient of settled funds.
MERCHANT_SIGNER_PRIVATE_KEY=0x
MERCHANT_PAYMENT_ADDRESS=0x
NEXUS_CORE_URL=https://api.nexus.platon.network
CHECKOUT_BASE_URL=https://nexus.platon.network
NEXUS_CHAIN_ID=20250407
NEXUS_WEBHOOK_SECRET=
WEBHOOK_SECRET=
